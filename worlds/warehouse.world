<?xml version="1.0" ?>
<!--
  Warehouse Simulation World — Gazebo Harmonic / Classic
  =======================================================
  A realistic warehouse with:
    - Metal shelving racks (3 rows × 8 bays)
    - Yellow safety lane markings on floor
    - 3 × Charging stations
    - Conveyor belt at dispatch area
    - Stacked pallets
    - 4 autonomous TugBots + 1 manual
    - Ambient + directional lighting (ceiling strips)

  Usage (Gazebo Classic):
    gazebo warehouse.world

  Usage (Gazebo Harmonic / ROS 2):
    ros2 launch warehouse_simulation gazebo.launch.py
-->
<sdf version="1.9">
  <world name="warehouse">

    <!-- ═══════════════════════════════════════════ -->
    <!-- Physics + rendering                         -->
    <!-- ═══════════════════════════════════════════ -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system"         name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"    name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-contact-system"          name="gz::sim::systems::Contact"/>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Sky + atmosphere                            -->
    <!-- ═══════════════════════════════════════════ -->
    <scene>
      <sky/>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.1 0.1 0.18 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Sun (directional light)                     -->
    <!-- ═══════════════════════════════════════════ -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>20 20 40 0 0 0</pose>
      <diffuse>0.9 0.9 0.8 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>-0.5 -0.5 -1</direction>
    </light>

    <!-- Ceiling strip lights -->
    <light type="point" name="light_1">
      <pose>-20 0 9 0 0 0</pose>
      <diffuse>1 0.98 0.9 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation><range>30</range><linear>0.05</linear></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>
    <light type="point" name="light_2">
      <pose>-10 0 9 0 0 0</pose>
      <diffuse>1 0.98 0.9 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation><range>30</range><linear>0.05</linear></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>
    <light type="point" name="light_3">
      <pose>0 0 9 0 0 0</pose>
      <diffuse>1 0.98 0.9 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation><range>30</range><linear>0.05</linear></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>
    <light type="point" name="light_4">
      <pose>10 0 9 0 0 0</pose>
      <diffuse>1 0.98 0.9 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation><range>30</range><linear>0.05</linear></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>
    <light type="point" name="light_5">
      <pose>20 0 9 0 0 0</pose>
      <diffuse>1 0.98 0.9 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation><range>30</range><linear>0.05</linear></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Ground plane                                -->
    <!-- ═══════════════════════════════════════════ -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>100 60</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>100 60</size></plane></geometry>
          <material>
            <ambient>0.82 0.82 0.82 1</ambient>
            <diffuse>0.82 0.82 0.82 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Warehouse structure (walls + ceiling)       -->
    <!-- ═══════════════════════════════════════════ -->
    <model name="warehouse">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>

      <!-- Back wall -->
      <link name="wall_back">
        <pose>0 -18 5 0 0 0</pose>
        <collision name="c"><geometry><box><size>60 0.5 10</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>60 0.5 10</size></box></geometry>
          <material><ambient>0.35 0.35 0.4 1</ambient><diffuse>0.35 0.35 0.4 1</diffuse></material>
        </visual>
      </link>

      <!-- Front wall -->
      <link name="wall_front">
        <pose>0 18 5 0 0 0</pose>
        <collision name="c"><geometry><box><size>60 0.5 10</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>60 0.5 10</size></box></geometry>
          <material><ambient>0.35 0.35 0.4 1</ambient><diffuse>0.35 0.35 0.4 1</diffuse></material>
        </visual>
      </link>

      <!-- Left wall -->
      <link name="wall_left">
        <pose>-30 0 5 0 0 0</pose>
        <collision name="c"><geometry><box><size>0.5 36 10</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>0.5 36 10</size></box></geometry>
          <material><ambient>0.35 0.35 0.4 1</ambient><diffuse>0.35 0.35 0.4 1</diffuse></material>
        </visual>
      </link>

      <!-- Right wall (with loading dock openings) -->
      <link name="wall_right_top">
        <pose>30 12 5 0 0 0</pose>
        <collision name="c"><geometry><box><size>0.5 12 10</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>0.5 12 10</size></box></geometry>
          <material><ambient>0.35 0.35 0.4 1</ambient><diffuse>0.35 0.35 0.4 1</diffuse></material>
        </visual>
      </link>
      <link name="wall_right_bottom">
        <pose>30 -12 5 0 0 0</pose>
        <collision name="c"><geometry><box><size>0.5 12 10</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>0.5 12 10</size></box></geometry>
          <material><ambient>0.35 0.35 0.4 1</ambient><diffuse>0.35 0.35 0.4 1</diffuse></material>
        </visual>
      </link>
      <!-- Dock door headers -->
      <link name="door_header_1">
        <pose>30 -8 7.5 0 0 0</pose>
        <collision name="c"><geometry><box><size>0.5 4 5</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>0.5 4 5</size></box></geometry>
          <material><ambient>0.15 0.2 0.3 1</ambient><diffuse>0.15 0.2 0.3 1</diffuse></material>
        </visual>
      </link>
      <link name="door_header_2">
        <pose>30 0 7.5 0 0 0</pose>
        <collision name="c"><geometry><box><size>0.5 4 5</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>0.5 4 5</size></box></geometry>
          <material><ambient>0.15 0.2 0.3 1</ambient><diffuse>0.15 0.2 0.3 1</diffuse></material>
        </visual>
      </link>
      <link name="door_header_3">
        <pose>30 8 7.5 0 0 0</pose>
        <collision name="c"><geometry><box><size>0.5 4 5</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>0.5 4 5</size></box></geometry>
          <material><ambient>0.15 0.2 0.3 1</ambient><diffuse>0.15 0.2 0.3 1</diffuse></material>
        </visual>
      </link>

      <!-- Ceiling -->
      <link name="ceiling">
        <pose>0 0 10 0 0 0</pose>
        <visual name="v">
          <geometry><box><size>60 36 0.3</size></box></geometry>
          <material><ambient>0.25 0.25 0.3 1</ambient><diffuse>0.25 0.25 0.3 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Yellow safety lane markings                 -->
    <!-- ═══════════════════════════════════════════ -->
    <model name="safety_lanes">
      <static>true</static>
      <!-- Aisle A -->
      <link name="lane_A_L">
        <pose>0 6.8 0.005 0 0 0</pose>
        <visual name="v"><geometry><box><size>58 0.5 0.01</size></box></geometry>
          <material><ambient>1 0.78 0 1</ambient><diffuse>1 0.78 0 1</diffuse></material></visual>
      </link>
      <link name="lane_A_C">
        <pose>0 7.4 0.005 0 0 0</pose>
        <visual name="v"><geometry><box><size>58 0.15 0.01</size></box></geometry>
          <material><ambient>1 0.9 0.1 1</ambient><diffuse>1 0.9 0.1 1</diffuse></material></visual>
      </link>
      <!-- Aisle B -->
      <link name="lane_B_L">
        <pose>0 -2.2 0.005 0 0 0</pose>
        <visual name="v"><geometry><box><size>58 0.5 0.01</size></box></geometry>
          <material><ambient>1 0.78 0 1</ambient><diffuse>1 0.78 0 1</diffuse></material></visual>
      </link>
      <link name="lane_B_C">
        <pose>0 -1.6 0.005 0 0 0</pose>
        <visual name="v"><geometry><box><size>58 0.15 0.01</size></box></geometry>
          <material><ambient>1 0.9 0.1 1</ambient><diffuse>1 0.9 0.1 1</diffuse></material></visual>
      </link>
      <!-- Aisle C -->
      <link name="lane_C_L">
        <pose>0 -13.2 0.005 0 0 0</pose>
        <visual name="v"><geometry><box><size>58 0.5 0.01</size></box></geometry>
          <material><ambient>1 0.78 0 1</ambient><diffuse>1 0.78 0 1</diffuse></material></visual>
      </link>
      <link name="lane_C_C">
        <pose>0 -12.6 0.005 0 0 0</pose>
        <visual name="v"><geometry><box><size>58 0.15 0.01</size></box></geometry>
          <material><ambient>1 0.9 0.1 1</ambient><diffuse>1 0.9 0.1 1</diffuse></material></visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Shelf macro (repeated 24 times)             -->
    <!-- shelf_big_0  … shelf_big_7  = Row A (yellow)-->
    <!-- shelf_0 … shelf_7           = Row B         -->
    <!-- shelf_c_0 … shelf_c_7       = Row C         -->
    <!-- ═══════════════════════════════════════════ -->

    <!-- Row A shelves at y=10 (yellow frames) -->
    <model name="shelf_big_0"><static>true</static><pose>-22 10 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.83 0.63 0 1</ambient><diffuse>0.83 0.63 0 1</diffuse></material></visual></link></model>

    <model name="shelf_big_1"><static>true</static><pose>-16 10 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.83 0.63 0 1</ambient><diffuse>0.83 0.63 0 1</diffuse></material></visual></link></model>

    <model name="shelf_big_2"><static>true</static><pose>-10 10 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.83 0.63 0 1</ambient><diffuse>0.83 0.63 0 1</diffuse></material></visual></link></model>

    <model name="shelf_big_3"><static>true</static><pose>-4 10 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.83 0.63 0 1</ambient><diffuse>0.83 0.63 0 1</diffuse></material></visual></link></model>

    <model name="shelf_big_4"><static>true</static><pose>4 10 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.83 0.63 0 1</ambient><diffuse>0.83 0.63 0 1</diffuse></material></visual></link></model>

    <model name="shelf_big_5"><static>true</static><pose>10 10 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.83 0.63 0 1</ambient><diffuse>0.83 0.63 0 1</diffuse></material></visual></link></model>

    <model name="shelf_big_6"><static>true</static><pose>16 10 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.83 0.63 0 1</ambient><diffuse>0.83 0.63 0 1</diffuse></material></visual></link></model>

    <model name="shelf_big_7"><static>true</static><pose>22 10 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.83 0.63 0 1</ambient><diffuse>0.83 0.63 0 1</diffuse></material></visual></link></model>

    <!-- Row B (grey) -->
    <model name="shelf_0"><static>true</static><pose>-22 1 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.29 0.31 0.37 1</ambient><diffuse>0.29 0.31 0.37 1</diffuse></material></visual></link></model>
    <model name="shelf_1"><static>true</static><pose>-16 1 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.29 0.31 0.37 1</ambient><diffuse>0.29 0.31 0.37 1</diffuse></material></visual></link></model>
    <model name="shelf_2"><static>true</static><pose>-10 1 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.29 0.31 0.37 1</ambient><diffuse>0.29 0.31 0.37 1</diffuse></material></visual></link></model>
    <model name="shelf_3"><static>true</static><pose>-4 1 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.29 0.31 0.37 1</ambient><diffuse>0.29 0.31 0.37 1</diffuse></material></visual></link></model>
    <model name="shelf_4"><static>true</static><pose>4 1 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.29 0.31 0.37 1</ambient><diffuse>0.29 0.31 0.37 1</diffuse></material></visual></link></model>
    <model name="shelf_5"><static>true</static><pose>10 1 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.29 0.31 0.37 1</ambient><diffuse>0.29 0.31 0.37 1</diffuse></material></visual></link></model>
    <model name="shelf_6"><static>true</static><pose>16 1 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.29 0.31 0.37 1</ambient><diffuse>0.29 0.31 0.37 1</diffuse></material></visual></link></model>
    <model name="shelf_7"><static>true</static><pose>22 1 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.29 0.31 0.37 1</ambient><diffuse>0.29 0.31 0.37 1</diffuse></material></visual></link></model>

    <!-- Row C (grey) -->
    <model name="shelf_c0"><static>true</static><pose>-22 -10 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.29 0.31 0.37 1</ambient><diffuse>0.29 0.31 0.37 1</diffuse></material></visual></link></model>
    <model name="shelf_c1"><static>true</static><pose>-16 -10 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.29 0.31 0.37 1</ambient><diffuse>0.29 0.31 0.37 1</diffuse></material></visual></link></model>
    <model name="shelf_c2"><static>true</static><pose>-10 -10 0 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.29 0.31 0.37 1</ambient><diffuse>0.29 0.31 0.37 1</diffuse></material></visual></link></model>
