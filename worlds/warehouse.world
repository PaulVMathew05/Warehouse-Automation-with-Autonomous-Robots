      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.29 0.31 0.37 1</ambient><diffuse>0.29 0.31 0.37 1</diffuse></material></visual></link></model>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Charging stations                           -->
    <!-- ═══════════════════════════════════════════ -->
    <model name="charging_station_0">
      <static>true</static><pose>-26 -16 0 0 0 0</pose>
      <link name="base">
        <visual name="v"><geometry><box><size>2.5 2 0.1</size></box></geometry><pose>0 0 0.05 0 0 0</pose>
          <material><ambient>0.13 0.2 0.27 1</ambient><diffuse>0.13 0.2 0.27 1</diffuse></material></visual>
      </link>
      <link name="pad">
        <visual name="v"><geometry><cylinder><radius>0.85</radius><length>0.02</length></cylinder></visual><pose>0 0 0.11 0 0 0</pose>
          <material><ambient>1 0.42 0.21 1</ambient><diffuse>1 0.42 0.21 1</diffuse></material></visual>
      </link>
    </model>

    <model name="charging_station_1">
      <static>true</static><pose>-22 -16 0 0 0 0</pose>
      <link name="base">
        <visual name="v"><geometry><box><size>2.5 2 0.1</size></box></geometry><pose>0 0 0.05 0 0 0</pose>
          <material><ambient>0.13 0.2 0.27 1</ambient><diffuse>0.13 0.2 0.27 1</diffuse></material></visual>
      </link>
      <link name="pad">
        <visual name="v"><geometry><cylinder><radius>0.85</radius><length>0.02</length></cylinder></visual><pose>0 0 0.11 0 0 0</pose>
          <material><ambient>1 0.42 0.21 1</ambient><diffuse>1 0.42 0.21 1</diffuse></material></visual>
      </link>
    </model>

    <model name="charging_station_2">
      <static>true</static><pose>-18 -16 0 0 0 0</pose>
      <link name="base">
        <visual name="v"><geometry><box><size>2.5 2 0.1</size></box></geometry><pose>0 0 0.05 0 0 0</pose>
          <material><ambient>0.13 0.2 0.27 1</ambient><diffuse>0.13 0.2 0.27 1</diffuse></material></visual>
      </link>
      <link name="pad">
        <visual name="v"><geometry><cylinder><radius>0.85</radius><length>0.02</length></cylinder></visual><pose>0 0 0.11 0 0 0</pose>
          <material><ambient>1 0.42 0.21 1</ambient><diffuse>1 0.42 0.21 1</diffuse></material></visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════ -->
    <!-- TugBot robots (differential drive)          -->
    <!-- ═══════════════════════════════════════════ -->
    <model name="tugbot_1">
      <pose>-26 14 0.26 0 0 0</pose>
      <link name="base_link">
        <inertial>
          <mass>20</mass>
          <inertia><ixx>0.5</ixx><iyy>0.5</iyy><izz>0.8</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
        <collision name="body_col">
          <geometry><cylinder><radius>0.48</radius><length>0.36</length></cylinder></geometry>
        </collision>
        <visual name="body_vis">
          <geometry><cylinder><radius>0.48</radius><length>0.36</length></cylinder></geometry>
          <material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.95 0.95 0.95 1</diffuse></material>
        </visual>
        <!-- LED ring visual -->
        <visual name="led_ring">
          <pose>0 0 0.05 0 0 0</pose>
          <geometry><cylinder><radius>0.44</radius><length>0.04</length></cylinder></geometry>
          <material><ambient>0 0.78 1 1</ambient><diffuse>0 0.78 1 1</diffuse><emissive>0 0.6 1 1</emissive></material>
        </visual>
      </link>

      <!-- Left wheel -->
      <link name="left_wheel">
        <pose>0.48 0 -0.1 -1.5707 0 0</pose>
        <inertial><mass>1</mass><inertia><ixx>0.01</ixx><iyy>0.01</iyy><izz>0.02</izz></inertia></inertial>
        <collision name="c"><geometry><cylinder><radius>0.16</radius><length>0.08</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.16</radius><length>0.08</length></cylinder></geometry>
          <material><ambient>0.13 0.13 0.13 1</ambient><diffuse>0.13 0.13 0.13 1</diffuse></material></visual>
      </link>
      <joint name="left_wheel_joint" type="revolute">
        <parent>base_link</parent><child>left_wheel</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit></axis>
      </joint>

      <!-- Right wheel -->
      <link name="right_wheel">
        <pose>-0.48 0 -0.1 -1.5707 0 0</pose>
        <inertial><mass>1</mass><inertia><ixx>0.01</ixx><iyy>0.01</iyy><izz>0.02</izz></inertia></inertial>
        <collision name="c"><geometry><cylinder><radius>0.16</radius><length>0.08</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.16</radius><length>0.08</length></cylinder></geometry>
          <material><ambient>0.13 0.13 0.13 1</ambient><diffuse>0.13 0.13 0.13 1</diffuse></material></visual>
      </link>
      <joint name="right_wheel_joint" type="revolute">
        <parent>base_link</parent><child>right_wheel</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit></axis>
      </joint>

      <!-- Diff drive plugin -->
      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.96</wheel_separation>
        <wheel_radius>0.16</wheel_radius>
        <odom_publish_frequency>10</odom_publish_frequency>
        <topic>/model/tugbot_1/cmd_vel</topic>
        <odom_topic>/model/tugbot_1/odometry</odom_topic>
        <frame_id>tugbot_1/odom</frame_id>
        <child_frame_id>tugbot_1/base_link</child_frame_id>
        <max_linear_acceleration>5</max_linear_acceleration>
      </plugin>

      <!-- Lidar -->
      <link name="lidar_link">
        <pose>0 0 0.24 0 0 0</pose>
        <sensor name="lidar" type="gpu_lidar">
          <topic>/model/tugbot_1/scan</topic>
          <update_rate>10</update_rate>
          <lidar>
            <scan><horizontal><samples>360</samples><resolution>1</resolution>
              <min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle></horizontal></scan>
            <range><min>0.2</min><max>20</max><resolution>0.01</resolution></range>
          </lidar>
          <visualize>false</visualize>
        </sensor>
      </link>
      <joint name="lidar_joint" type="fixed"><parent>base_link</parent><child>lidar_link</child></joint>

      <!-- Battery plugin -->
      <plugin filename="gz-sim-linearbatteryplugin-system" name="gz::sim::systems::LinearBatteryPlugin">
        <battery_name>linear_battery</battery_name>
        <voltage>12.694</voltage>
        <open_circuit_voltage_constant_coef>12.694</open_circuit_voltage_constant_coef>
        <open_circuit_voltage_linear_coef>-3.1424</open_circuit_voltage_linear_coef>
        <initial_charge>1.1665</initial_charge>
        <capacity>1.1665</capacity>
        <resistance>0.061523</resistance>
        <smooth_current_tau>1.9499</smooth_current_tau>
        <power_load>6.6</power_load>
        <start_on_motion>true</start_on_motion>
      </plugin>
    </model>

    <!-- ═══════════════════════════════════════════ -->
    <!-- TugBots 2–4 + Manual (external SDF models)  -->
    <!-- ═══════════════════════════════════════════ -->

    <include>
      <uri>model://tugbot</uri>
      <name>tugbot_2</name>
      <pose>-26 7 0.26 0 0 0</pose>
    </include>

    <include>
      <uri>model://tugbot</uri>
      <name>tugbot_3</name>
      <pose>-26 0 0.26 0 0 0</pose>
    </include>

    <include>
      <uri>model://tugbot</uri>
      <name>tugbot_4</name>
      <pose>-26 -7 0.26 0 0 0</pose>
    </include>

    <include>
      <uri>model://tugbot</uri>
      <name>tugbot_manual</name>
      <pose>-24 -14 0.26 0 0 0</pose>
    </include>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Forklifts                                    -->
    <!-- ═══════════════════════════════════════════ -->

    <!--
      Forklifts spawn near charging area (west side).
      Rear wheel radius = 0.42 m → spawn z = 0.44 to
      ensure the chassis clears the floor.
      Yaw = 1.5708 rad → facing +Y (into warehouse).
    -->
    <include>
      <uri>model://forklift</uri>
      <name>forklift_1</name>
      <pose>-24 2 0.44 0 0 1.5708</pose>
    </include>

    <include>
      <uri>model://forklift</uri>
      <name>forklift_2</name>
      <pose>-24 -2 0.44 0 0 1.5708</pose>
    </include>

    <!-- ═══════════════════════════════════════════ -->
    <!-- 5-DOF Robotic Arm  (dispatch area, east)    -->
    <!-- ═══════════════════════════════════════════ -->

    <!--
      The arm sits at x = 25.5, y = 0 (sim: x=25.5, z=0).
      arm_base is a heavy disc; it rests flat on the floor (z=0).
    -->
    <include>
      <uri>model://robotic_arm</uri>
      <name>robotic_arm</name>
      <pose>25.5 0 0 0 0 0</pose>
    </include>

  </world>
</sdf>
