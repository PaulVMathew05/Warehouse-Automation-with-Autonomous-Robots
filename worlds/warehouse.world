      <link name="l"><collision name="c"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose></collision>
      <visual name="v"><geometry><box><size>4 2 4.5</size></box></geometry><pose>0 0 2.25 0 0 0</pose>
      <material><ambient>0.29 0.31 0.37 1</ambient><diffuse>0.29 0.31 0.37 1</diffuse></material></visual></link></model>
