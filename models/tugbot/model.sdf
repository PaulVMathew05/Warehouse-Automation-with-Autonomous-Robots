<?xml version="1.0" ?>
<!--
  TugBot v2  —  Autonomous Warehouse Tugbot
  ==========================================
  Differential drive, 360-deg LIDAR, IMU, battery.
  Compatible with Gazebo Harmonic + ROS 2 Humble.

  Topics (via ros_gz_bridge):
    /tugbot_N/cmd_vel    ← geometry_msgs/Twist
    /tugbot_N/odom       → nav_msgs/Odometry
    /tugbot_N/scan       → sensor_msgs/LaserScan
    /tugbot_N/imu        → sensor_msgs/Imu
    /tugbot_N/battery    → sensor_msgs/BatteryState
-->
<sdf version="1.9">
  <model name="tugbot">
    <pose>0 0 0.26 0 0 0</pose>

    <!-- ── Base chassis ─────────────────────────────────────── -->
    <link name="base_link">
      <inertial>
        <mass>22.0</mass>
        <inertia>
          <ixx>0.98</ixx><iyy>1.45</iyy><izz>1.68</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>

      <!-- Body collision -->
      <collision name="body_col">
        <pose>0 0 0 0 0 0</pose>
        <geometry><box><size>0.90 1.10 0.72</size></box></geometry>
        <surface>
          <friction><ode><mu>0.5</mu><mu2>0.5</mu2></ode></friction>
          <contact><ode><max_vel>0.01</max_vel><min_depth>0.001</min_depth></ode></contact>
        </surface>
      </collision>

      <!-- Body visual — dark chassis -->
      <visual name="body_vis">
        <pose>0 0 0 0 0 0</pose>
        <geometry><box><size>0.90 1.10 0.72</size></box></geometry>
        <material>
          <ambient>0.10 0.13 0.23 1</ambient>
          <diffuse>0.12 0.16 0.28 1</diffuse>
          <specular>0.2 0.2 0.3 0.5</specular>
        </material>
      </visual>

      <!-- Top panel -->
      <visual name="top_panel_vis">
        <pose>0 0 0.39 0 0 0</pose>
        <geometry><box><size>0.86 1.06 0.06</size></box></geometry>
        <material><ambient>0.05 0.10 0.18 1</ambient><diffuse>0.05 0.10 0.18 1</diffuse></material>
      </visual>

      <!-- LED ring (emissive strip) -->
      <visual name="led_ring_vis">
        <pose>0 0 0.04 0 0 0</pose>
        <geometry><cylinder><radius>0.42</radius><length>0.04</length></geometry>
        <material>
          <ambient>0 0.78 1 1</ambient>
          <diffuse>0 0.78 1 1</diffuse>
          <emissive>0 0.78 1 0.8</emissive>
        </material>
      </visual>

      <!-- Safety bumper (front, orange) -->
      <visual name="bumper_vis">
        <pose>0 0.57 -0.08 0 0 0</pose>
        <geometry><box><size>0.84 0.06 0.12</size></box></geometry>
        <material><ambient>1 0.33 0 1</ambient><diffuse>1 0.33 0 1</diffuse><emissive>0.4 0.13 0 1</emissive></material>
      </visual>

      <!-- LIDAR housing (black cylinder on top) -->
      <visual name="lidar_housing_vis">
        <pose>0 0 0.49 0 0 0</pose>
        <geometry><cylinder><radius>0.15</radius><length>0.14</length></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material>
      </visual>

      <!-- LIDAR sensor -->
      <sensor name="lidar" type="gpu_lidar">
        <pose>0 0 0.60 0 0 0</pose>
        <update_rate>10</update_rate>
        <topic>/tugbot/scan</topic>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.15</min>
            <max>12.0</max>
            <resolution>0.02</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
        <visualize>false</visualize>
      </sensor>

      <!-- IMU sensor -->
      <sensor name="imu" type="imu">
        <pose>0 0 0 0 0 0</pose>
        <update_rate>50</update_rate>
        <topic>/tugbot/imu</topic>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.0004</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.0004</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.0004</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>

    <!-- ── Left drive wheel ──────────────────────────────────── -->
    <link name="wheel_left">
      <pose>-0.55 0 -0.05 -1.5708 0 0</pose>
      <inertial>
        <mass>1.4</mass>
        <inertia><ixx>0.0103</ixx><iyy>0.0103</iyy><izz>0.0196</izz></inertia>
      </inertial>
      <collision name="c">
        <geometry><cylinder><radius>0.21</radius><length>0.13</length></geometry>
        <surface>
          <friction><ode><mu>1.5</mu><mu2>0.5</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="v">
        <geometry><cylinder><radius>0.21</radius><length>0.13</length></geometry>
        <material><ambient>0.07 0.07 0.09 1</ambient><diffuse>0.1 0.1 0.12 1</diffuse><specular>0.2 0.2 0.2 1</specular></material>
      </visual>
      <!-- Hubcap -->
      <visual name="hubcap">
        <pose>0 0.07 0 0 0 0</pose>
        <geometry><cylinder><radius>0.10</radius><length>0.01</length></geometry>
        <material><ambient>0.5 0.5 0.3 1</ambient><diffuse>0.5 0.5 0.3 1</diffuse></material>
      </visual>
    </link>
    <joint name="wheel_left_joint" type="revolute">
      <parent>base_link</parent><child>wheel_left</child>
      <axis><xyz>0 0 1</xyz><limit><effort>50</effort><velocity>20</velocity></limit>
        <dynamics><damping>0.004</damping><friction>0.001</friction></dynamics>
      </axis>
    </joint>

    <!-- ── Right drive wheel ─────────────────────────────────── -->
    <link name="wheel_right">
      <pose>0.55 0 -0.05 -1.5708 0 0</pose>
      <inertial>
        <mass>1.4</mass>
        <inertia><ixx>0.0103</ixx><iyy>0.0103</iyy><izz>0.0196</izz></inertia>
      </inertial>
      <collision name="c">
        <geometry><cylinder><radius>0.21</radius><length>0.13</length></geometry>
        <surface><friction><ode><mu>1.5</mu><mu2>0.5</mu2></ode></friction></surface>
      </collision>
      <visual name="v">
        <geometry><cylinder><radius>0.21</radius><length>0.13</length></geometry>
        <material><ambient>0.07 0.07 0.09 1</ambient><diffuse>0.1 0.1 0.12 1</diffuse><specular>0.2 0.2 0.2 1</specular></material>
      </visual>
      <visual name="hubcap">
        <pose>0 -0.07 0 0 0 0</pose>
        <geometry><cylinder><radius>0.10</radius><length>0.01</length></geometry>
        <material><ambient>0.5 0.5 0.3 1</ambient><diffuse>0.5 0.5 0.3 1</diffuse></material>
      </visual>
    </link>
    <joint name="wheel_right_joint" type="revolute">
      <parent>base_link</parent><child>wheel_right</child>
      <axis><xyz>0 0 1</xyz><limit><effort>50</effort><velocity>20</velocity></limit>
        <dynamics><damping>0.004</damping><friction>0.001</friction></dynamics>
      </axis>
    </joint>

    <!-- ── Front caster ──────────────────────────────────────── -->
    <link name="caster_front">
      <pose>0 0.46 -0.16 0 0 0</pose>
      <inertial><mass>0.3</mass><inertia><ixx>0.00025</ixx><iyy>0.00025</iyy><izz>0.00025</izz></inertia></inertial>
      <collision name="c">
        <geometry><sphere><radius>0.10</radius></sphere></geometry>
        <surface><friction><ode><mu>0.01</mu><mu2>0.01</mu2></ode></friction></surface>
      </collision>
      <visual name="v">
        <geometry><sphere><radius>0.10</radius></sphere></geometry>
        <material><ambient>0.20 0.20 0.25 1</ambient><diffuse>0.20 0.20 0.25 1</diffuse></material>
      </visual>
    </link>
    <joint name="caster_front_joint" type="ball">
      <parent>base_link</parent><child>caster_front</child>
    </joint>

    <!-- ── Rear caster ───────────────────────────────────────── -->
    <link name="caster_rear">
      <pose>0 -0.46 -0.16 0 0 0</pose>
      <inertial><mass>0.3</mass><inertia><ixx>0.00025</ixx><iyy>0.00025</iyy><izz>0.00025</izz></inertia></inertial>
      <collision name="c">
        <geometry><sphere><radius>0.10</radius></sphere></geometry>
        <surface><friction><ode><mu>0.01</mu><mu2>0.01</mu2></ode></friction></surface>
      </collision>
      <visual name="v">
        <geometry><sphere><radius>0.10</radius></sphere></geometry>
        <material><ambient>0.20 0.20 0.25 1</ambient><diffuse>0.20 0.20 0.25 1</diffuse></material>
      </visual>
    </link>
    <joint name="caster_rear_joint" type="ball">
      <parent>base_link</parent><child>caster_rear</child>
    </joint>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- Gazebo Harmonic Plugins                                -->
    <!-- ══════════════════════════════════════════════════════ -->

    <!-- Differential drive -->
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>1.10</wheel_separation>
      <wheel_radius>0.21</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <max_linear_acceleration>2.5</max_linear_acceleration>
      <max_angular_acceleration>3.0</max_angular_acceleration>
    </plugin>

    <!-- Joint state publisher -->
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <update_rate>20</update_rate>
    </plugin>

    <!-- Linear battery -->
    <plugin filename="gz-sim-linearbatteryplugin-system"
            name="gz::sim::systems::LinearBatteryPlugin">
      <battery_name>warehouse_battery</battery_name>
      <voltage>24.0</voltage>
      <open_circuit_voltage_constant_coef>24.0</open_circuit_voltage_constant_coef>
      <open_circuit_voltage_linear_coef>-6.0</open_circuit_voltage_linear_coef>
      <initial_charge>80.0</initial_charge>
      <capacity>80.0</capacity>
      <resistance>0.06</resistance>
      <smooth_current_tau>2.0</smooth_current_tau>
      <power_load>8.0</power_load>
      <start_on_motion>true</start_on_motion>
    </plugin>

    <!-- Odometry publisher -->
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <publish_rate>20</publish_rate>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
    </plugin>

  </model>
</sdf>
